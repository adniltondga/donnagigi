{
  "expo": {
    "name": "AgLivre",
    "slug": "aglivre-app",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "aglivre",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#6d28d9"
    },
    "updates": {
      "fallbackToCacheTimeout": 0,
      "url": "https://u.expo.dev/1e22b38a-eca9-442d-b72b-bfdeae9cbac8"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "br.com.aglivre.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSFaceIDUsageDescription": "Use Face ID pra entrar no AgLivre rapidamente sem digitar a senha."
      }
    },
    "android": {
      "package": "br.com.aglivre.app",
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#6d28d9"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#6d28d9"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Permite escanear códigos de barras dos produtos."
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Use Face ID pra entrar no AgLivre rapidamente sem digitar a senha."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "1e22b38a-eca9-442d-b72b-bfdeae9cbac8"
      }
    },
    "owner": "adniltonweb"
  }
}
