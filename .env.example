# Environment Variables Template
# Copy this file to .env.local and fill in your actual values

# Database Connection (PostgreSQL - NEON)
# Get from: https://console.neon.tech
DATABASE_URL=postgresql://neondb_owner:password@ep-xxxxx.neon.tech/neondb?sslmode=require

# Direct URL for migrations (same as DATABASE_URL for local dev)
DIRECT_DATABASE_URL=postgresql://neondb_owner:password@ep-xxxxx.neon.tech/neondb?sslmode=require

# JWT Secret for authentication
# Generate with: node generate-jwt-secret.js
JWT_SECRET=generate_with_node_script_32_characters_minimum

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Environment
NODE_ENV=development
