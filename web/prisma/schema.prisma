// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Tenant (cliente do SaaS agLivre). Cada cliente que se cadastra no
// produto cria um Tenant; todos os dados (produtos, bills, integrações,
// custos, fornecedores) são escopados por tenantId.
model Tenant {
  id        String   @id @default(cuid())
  name      String   // nome comercial exibido ao cliente
  slug      String   @unique // identificador URL-friendly (ex: "dona-gigi")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Soft delete (LGPD direito ao esquecimento). Quando preenchido,
  // bloqueia acesso ao admin e agenda hard delete em 30 dias via
  // cron account-purge. Usuário pode reativar antes do prazo.
  deletedAt DateTime?

  users             User[]
  products          Product[]
  productVariants   ProductVariant[]
  bills             Bill[]
  suppliers         Supplier[]
  mlIntegrations    MLIntegration[]
  mlProductCosts    MLProductCost[]
  mlProductVariantCosts MLProductVariantCost[]
  subscription      Subscription?
  mlAppCredentials  MLAppCredentials?
  mpAppCredentials  MPAppCredentials?
  mpIntegration     MPIntegration?
  invitations       Invitation[]
  billCategories    BillCategory[]
  notifications     Notification[]
  pushSubscriptions PushSubscription[]
  financialSettings FinancialSettings?
  tickets           Ticket[]
}

// Credenciais do app do cliente no Mercado Livre DevCenter.
// Cada tenant registra seu PRÓPRIO app no ML e guarda clientId +
// clientSecret aqui. O fluxo OAuth (login/callback/refresh) usa essas
// credenciais. Fallback: se o tenant não tiver cadastrado, usa o
// ML_CLIENT_ID/ML_CLIENT_SECRET do .env (app global do SaaS).
model MLAppCredentials {
  id           String   @id @default(cuid())
  tenantId     String   @unique
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  clientId     String
  clientSecret String
  redirectUri  String?  // URI cadastrada no DevCenter do cliente (opcional — fallback: .env ou derivado do request)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// Assinatura do tenant (1:1) — ASAAS cuida do billing real
model Subscription {
  id                  String              @id @default(cuid())
  tenantId            String              @unique
  tenant              Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  plan                SubscriptionPlan    @default(FREE)
  status              SubscriptionStatus  @default(TRIAL)
  billingType         BillingType?
  value               Float?

  // Referências ASAAS
  asaasCustomerId     String?
  asaasSubscriptionId String?

  // Ciclo de vida
  trialEndsAt         DateTime?
  currentPeriodStart  DateTime?
  currentPeriodEnd    DateTime?
  canceledAt          DateTime?

  // Idempotência de emails de dunning. Tipos: trial_t3, trial_t1,
  // trial_expired, payment_overdue, payment_confirmed, canceled.
  lastDunningType     String?
  lastDunningAt       DateTime?

  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  invoices            Invoice[]

  @@index([asaasCustomerId])
  @@index([asaasSubscriptionId])
}

// Fatura (payment) gerada pela ASAAS. Alimentada via webhook.
model Invoice {
  id              String       @id @default(cuid())
  subscriptionId  String
  subscription    Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  asaasPaymentId  String       @unique
  value           Float
  status          String // PENDING, CONFIRMED, RECEIVED, OVERDUE, REFUNDED, CANCELED
  billingType     BillingType?
  dueDate         DateTime
  paymentDate     DateTime?

  invoiceUrl      String?      // checkout ASAAS (PIX/boleto)
  bankSlipUrl     String?

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([subscriptionId])
}

enum SubscriptionPlan {
  FREE
  PRO
}

enum SubscriptionStatus {
  TRIAL       // 14 dias grátis
  ACTIVE      // pagamento confirmado
  PENDING     // aguardando primeiro pagamento
  OVERDUE     // pagamento atrasado
  CANCELED    // cancelado pelo user
  EXPIRED     // trial acabou ou ASAAS cancelou
}

enum BillingType {
  PIX
  BOLETO
  CREDIT_CARD
}

// Papel do usuário dentro do tenant.
// OWNER  — dono do tenant. Único. Faz tudo, inclusive assinatura.
// ADMIN  — sócio/gestor. Mexe em tudo exceto billing/tenant.
// VIEWER — funcionário. Só leitura (dashboard, relatórios, pedidos).
enum UserRole {
  OWNER
  ADMIN
  VIEWER
}

// Status do ciclo de vida de um chamado de suporte.
//   OPEN            - aberto pelo cliente, ainda não atendido
//   IN_PROGRESS     - staff respondeu e está cuidando
//   WAITING_CLIENT  - staff aguardando informação do cliente
//   CLOSED          - resolvido / encerrado
enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_CLIENT
  CLOSED
}

enum TicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

// Categorias usadas pra classificar tickets — útil pra filtros e roteamento.
enum TicketCategory {
  BUG
  DUVIDA
  INTEGRACAO
  FINANCEIRO
  OUTRO
}

// Quem escreveu uma TicketMessage.
enum MessageAuthorRole {
  CLIENT
  STAFF
}

// Usuário admin do sistema
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  username  String   @unique
  password  String
  name      String
  role      UserRole @default(VIEWER)
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Verificação de email (OTP de 6 dígitos)
  emailVerified       Boolean   @default(false)
  verifyCode          String?
  verifyCodeExpires   DateTime?
  verifyLastSentAt    DateTime? // cooldown de reenvio

  // Reset de senha (OTP de 6 dígitos)
  resetCode           String?
  resetCodeExpires    DateTime?
  resetLastSentAt     DateTime?

  invitesCreated Invitation[] @relation("InvitationCreatedBy")

  // Suporte interno: usuário marcado como staff (DGA Digital) acessa /staff
  // e responde tickets. Toggle manual no banco — sem UI de gestão por enquanto.
  isStaff Boolean @default(false)

  ticketsOpened   Ticket[]         @relation("TicketOpenedBy")
  ticketsAssigned Ticket[]         @relation("TicketAssignee")
  ticketMessages  TicketMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([isStaff])
}

// Convite pendente pra entrar num tenant. Criado pelo OWNER/ADMIN.
// Consumido em /convite/<token> — vira User ao ser aceito.
model Invitation {
  id           String    @id @default(cuid())
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email        String
  role         UserRole
  token        String    @unique
  expiresAt    DateTime
  acceptedAt   DateTime?
  createdById  String
  createdBy    User      @relation("InvitationCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([tenantId])
  @@index([email])
}

// Produto base (título do produto)
model Product {
  id          String   @id @default(cuid())
  name        String   // Título do produto
  description String?  @db.Text

  // Preço base e estoque
  baseSalePrice Float?
  minStock      Int     @default(0)

  // Custos de venda
  productCost   Float?  // custo da mercadoria/produção

  // Mercado Livre
  mlListingId   String?

  // Status
  active        Boolean @default(true)

  // Tenant owner
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relações
  variants      ProductVariant[]
  bills         Bill[]
  images        ProductImage[]

  @@index([tenantId])
  @@index([tenantId, active])
  @@unique([tenantId, mlListingId])
}

// Imagens do produto
model ProductImage {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String   // URL final no Vercel Blob
  mlUrl     String?  // URL original do ML (referência)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
}

// Imagens da variação (específica para cada variação do produto)
model VariantImage {
  id        String         @id @default(cuid())
  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  url       String         // URL final no Vercel Blob
  mlUrl     String?        // URL original do ML (referência)
  order     Int            @default(0)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([variantId])
}

// Variação do produto (cor, tamanho, etc)
model ProductVariant {
  id        String   @id @default(cuid())

  // Relação com produto
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  // Tenant (escopa o `cod`/SKU por cliente — denormalizado de Product
  // pra permitir @@unique([tenantId, cod]) sem JOIN).
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Informações
  title     String?  // Título específico da variante (ex: "Capinha iPhone 15 - Preto")
  cod       String

  // Preço e estoque
  salePrice Float
  stock     Int      @default(0)

  // Mercado Livre
  mlListingId String?

  // Status
  active    Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relações
  mlProducts MLProduct[]
  images     VariantImage[]

  @@unique([tenantId, cod])
  @@index([productId, active])
}

// Custo cadastrado por listing do Mercado Livre.
// Usado pelo sync-orders para abater automaticamente em vendas recorrentes.
// Fallback: quando não há custo específico por variação, usa este.
model MLProductCost {
  id          String   @id @default(cuid())
  mlListingId String
  title       String?
  productCost Float
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, mlListingId])
  @@index([tenantId])
}

// Custo por variação de um listing ML. Quando uma venda tem variation_id e
// existe registro aqui, este custo tem precedência sobre MLProductCost.
// variationId é o ID da variação retornado pela API do ML (ex: "191323520158").
model MLProductVariantCost {
  id            String   @id @default(cuid())
  mlListingId   String
  variationId   String
  variationName String?
  productCost   Float
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([tenantId, mlListingId, variationId])
  @@index([tenantId])
  @@index([mlListingId])
}

// Estado temporário do fluxo OAuth PKCE do Mercado Livre
// Armazena o code_verifier gerado no /login, indexado pelo state,
// para ser recuperado no /callback sem depender de cookies.
model MLOAuthState {
  state        String   @id
  codeVerifier String
  tenantId     String?  // tenantId do usuário que iniciou o OAuth (setado no callback)
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@index([expiresAt])
}

// Credenciais do app do cliente no Mercado Pago DevCenter.
// Mesmo padrão do MLAppCredentials: cada tenant pode cadastrar seu próprio
// app (APP_ID + secret) pra ter cotas isoladas e branding próprio, ou cair
// no fallback das env vars MP_CLIENT_ID / MP_CLIENT_SECRET.
model MPAppCredentials {
  id           String   @id @default(cuid())
  tenantId     String   @unique
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  clientId     String
  clientSecret String
  redirectUri  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// Integração OAuth ativa com o Mercado Pago (1 por tenant).
// Guarda tokens + user_id do seller no MP + cache do último snapshot
// consultado (evita bater na API do MP a cada abertura de tela).
model MPIntegration {
  id           String   @id @default(cuid())
  tenantId     String   @unique
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  mpUserId     String   // user_id do vendedor no MP
  accessToken  String
  refreshToken String?
  expiresAt    DateTime
  scope        String?

  // Cache do último snapshot (refresh manual ou cron)
  cachedUnavailableBalance Float?
  cachedPendingCount       Int?
  cachedReleasedTotal      Float?
  cachedReleasedCount      Int?
  cachedDisputedTotal      Float?
  cachedDisputedCount      Int?
  cachedPendingDays        Json?     // array de { date, total, count, payments[] } (futuro)
  cachedReleasedDays       Json?     // mesma estrutura, release_date passado
  cachedDisputedPayments   Json?     // array de payments em mediação
  cachedSyncedAt           DateTime?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// State temporário do fluxo OAuth do Mercado Pago (TTL curto).
// Guarda o codeVerifier (PKCE S256) pra trocar no callback.
model MPOAuthState {
  state        String   @id
  codeVerifier String
  tenantId     String
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@index([expiresAt])
}

// Integração com Mercado Livre
model MLIntegration {
  id           String   @id @default(cuid())
  sellerID     String
  accessToken  String
  refreshToken String?
  expiresAt    DateTime

  // Tenant owner (1 integração por tenant)
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relações
  products     MLProduct[]

  @@index([tenantId])
}

// Rastreamento de produtos no Mercado Livre
model MLProduct {
  id        String   @id @default(cuid())

  // Relação com variante
  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  // Relação com integração
  integrationId String
  integration   MLIntegration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  // Dados do ML
  mlListingId   String?
  status        String   @default("active")

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([variantId])
  @@index([integrationId])
  @@index([mlListingId])
}

// Fornecedor
model Supplier {
  id        String   @id @default(cuid())
  name      String
  bills     Bill[]
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
}

// Conta (contas a pagar/receber)
model Bill {
  id              String   @id @default(cuid())
  type            String   // "payable" | "receivable"
  description     String
  amount          Float
  dueDate         DateTime
  paidDate        DateTime?
  status          String   @default("pending") // pending | paid | overdue | cancelled
  category        String   @default("outro") // discriminador de tipo: 'venda' | 'marketplace_fee' | 'aporte_amortizacao' | 'reposicao_estoque' | 'outro'. NÃO é categoria do usuário — pra isso usar billCategoryId.
  billCategoryId  String?
  billCategory    BillCategory? @relation(fields: [billCategoryId], references: [id], onDelete: SetNull)
  supplierId      String?
  supplier        Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  productId       String?   // relaciona com o produto vendido
  product         Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  notes           String?  @db.Text
  productCost     Float?   // custo total da mercadoria (custo unitário × quantity)
  quantity        Int      @default(1) // unidades vendidas no pedido (soma de order_items[].quantity)
  mlOrderId       String?  @unique  // evita duplicatas de pedidos ML
  mlPackId        String?  // pack_id do ML (ID que aparece no painel "vendas" do seller)
  mlVariationId   String?  // variation_id do ML no item vendido (usado pelo cost-resolver)
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId])
  @@index([billCategoryId])
  @@index([tenantId, paidDate])
  @@index([tenantId, dueDate])
  @@index([tenantId, type, status])
  @@index([mlPackId])
}

// Configurações financeiras do tenant — alimenta o relatório de
// "pró-labore seguro" (Pay Yourself Last).
model FinancialSettings {
  id              String   @id @default(cuid())
  tenantId        String   @unique
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  reservaMeses    Int      @default(3)  // meses de despesa fixa a manter como colchão
  reinvestPct     Float    @default(20) // % do lucro líquido pra reinvestir
  reposicaoPct    Float    @default(50) // % da receita líquida reservada pro caixa de reposição de estoque
  saldoCaixaAtual Float?   // saldo em conta/caixa informado manualmente
  saldoAtualizadoEm DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Categoria hierárquica de contas (2 níveis: raiz + subcategoria).
// Escopo por tenant. type 'payable' | 'receivable' — define em qual
// aba a categoria aparece.
model BillCategory {
  id        String   @id @default(cuid())
  name      String
  type      String   // 'payable' | 'receivable'
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parentId  String?
  parent    BillCategory?  @relation("SubCategories", fields: [parentId], references: [id], onDelete: Cascade)
  children  BillCategory[] @relation("SubCategories")
  bills     Bill[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, parentId, name])
  @@index([tenantId])
  @@index([parentId])
}

// Audit log de exclusão de conta (LGPD). NÃO tem FK pra Tenant —
// preserva histórico mesmo após o hard delete (cascade). Snapshots
// dos dados essenciais ficam aqui.
model AccountDeletionLog {
  id              String    @id @default(cuid())
  tenantId        String    // snapshot — pode não existir mais após purge
  tenantSlug      String
  tenantName      String
  ownerEmail      String
  ownerName       String
  reason          String?   @db.Text  // pesquisa opcional
  ipAddress       String?
  userAgent       String?

  // Soft-deletado em DD; hard-deletado em DD+30
  softDeletedAt        DateTime  @default(now())
  scheduledHardDeleteAt DateTime
  hardDeletedAt        DateTime?  // preenchido pelo cron account-purge
  restoredAt           DateTime?  // preenchido se user reativar

  @@index([tenantId])
  @@index([scheduledHardDeleteAt])
}

// Subscription Web Push de um device. Cada user pode ter várias (1 por
// device/browser). Quando o backend dispara push (venda nova, liberação
// MP), envia pra todas as subscriptions ativas do tenant.
model PushSubscription {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
}

// Notificações in-app exibidas no sino do header. Per-tenant (se alguém
// lê, todo mundo do tenant vê como lida — simplifica o modelo pra loja
// pequena). Criadas pelo webhook ML quando uma venda nova chega.
model Notification {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  type      String   // ex: "sale", "refund", "mp_release", "system"
  title     String
  body      String?  // texto secundário (ex: "Comprador X · R$ 250")
  link      String?  // URL interna pra navegar ao clicar
  read      Boolean  @default(false)

  createdAt DateTime @default(now())

  @@index([tenantId, read, createdAt(sort: Desc)])
  @@index([tenantId, createdAt(sort: Desc)])
}

// Chamado de suporte aberto por um cliente. Threads de mensagens vivem
// em TicketMessage. Cliente acessa em /admin/suporte; staff (DGA) acessa
// em /staff/tickets pra responder.
model Ticket {
  id        String          @id @default(cuid())
  tenantId  String
  tenant    Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  openedById String
  openedBy   User           @relation("TicketOpenedBy", fields: [openedById], references: [id])

  // Staff atribuído pra cuidar do chamado. Null = ainda não atribuído.
  assigneeId String?
  assignee   User?          @relation("TicketAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  subject   String
  status    TicketStatus    @default(OPEN)
  priority  TicketPriority  @default(NORMAL)
  category  TicketCategory  @default(OUTRO)

  // Timestamps de "última resposta de cada lado" — útil pra ordenar por
  // urgência ("respondidos pelo cliente sem retorno do staff").
  lastClientReplyAt DateTime?
  lastStaffReplyAt  DateTime?

  messages  TicketMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  closedAt  DateTime?

  @@index([tenantId, createdAt(sort: Desc)])
  @@index([status])
  @@index([assigneeId])
}

// Mensagem dentro de um ticket. Cliente e staff escrevem aqui;
// authorRole distingue de quem é (mais robusto que olhar isStaff do
// author na hora da renderização — evita bug se staff virar não-staff).
model TicketMessage {
  id         String            @id @default(cuid())
  ticketId   String
  ticket     Ticket            @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  authorId   String
  author     User              @relation(fields: [authorId], references: [id])
  authorRole MessageAuthorRole

  body       String  // markdown simples; render via biblioteca cliente

  createdAt  DateTime @default(now())

  @@index([ticketId, createdAt])
}

// Lista de espera — captura email enquanto o cadastro estiver fechado
// (sistema em testes finais). Ao reabrir, manda broadcast pra todos.
// `source` ajuda a saber qual CTA converteu mais (home / planos / login).
model WaitlistSignup {
  id        String   @id @default(cuid())
  email     String   @unique
  source    String?  // ex: "home", "planos", "login"
  notified  Boolean  @default(false) // marcamos true quando enviarmos o "tá no ar"
  createdAt DateTime @default(now())

  @@index([createdAt])
}
