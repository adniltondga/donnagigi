// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  username  String   @unique
  password  String
  name      String?
  image     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relações
  orders Order[]
}

model Supplier {
  id        String   @id @default(cuid())
  name      String   @unique
  telephone String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  description String   @default("")
  icon        String? // emoji ou URL do ícone
  color       String   @default("#000000")
  active      Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relações
  products Product[]
}

// Modelo de dispositivo (iPhone 14 Pro Max, iPhone 15, etc)
model DeviceModel {
  id          String   @id @default(cuid())
  name        String   @unique // "iPhone 14 Pro Max", "Samsung S24"
  description String   @default("")
  icon        String? // emoji ou ícone
  color       String   @default("#000000") // Cor visual no admin
  active      Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relações
  modelColors DeviceModelColor[]
  variants    ProductVariant[]
}

// Cor de dispositivo (Preto, Azul, Rosa, etc)
model DeviceColor {
  id        String   @id @default(cuid())
  name      String   @unique // "Preto", "Azul", "Rosa"
  hexColor  String   @default("#000000") // Código hexadecimal da cor
  active    Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relações
  modelColors DeviceModelColor[]
  variants    ProductVariant[]
}

// Relacionamento: Dev quais modelos têm quais cores
model DeviceModelColor {
  id        String      @id @default(cuid())
  modelId   String
  model     DeviceModel @relation(fields: [modelId], references: [id], onDelete: Cascade)
  colorId   String
  color     DeviceColor @relation(fields: [colorId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@unique([modelId, colorId])
}

model Product {
  id          String    @id @default(cuid())
  name        String
  description String    @db.Text
  baseImage   String    @default("") // Imagem padrão do produto
  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  supplier    String? // "capa25"

  // Códigos de Marketplace
  mlListingId     String? // ID de anúncio no Mercado Livre
  shopeeListingId String? // ID de anúncio no Shopee

  // Preço base (pode ser sobrescrito por variante)
  baseSalePrice    Float? // Preço padrão
  basePurchaseCost Float  @default(0) // Custo-padrão
  baseBoxCost      Float  @default(0) // Custo caixa padrão
  baseMLTariff     Float  @default(0) // Tarifa Mercado Livre padrão
  baseDeliveryTariff Float @default(0) // Tarifa entrega padrão
  baseMLPrice      Float? // Preço Mercado Livre
  shopeePrice      Float? // Preço Shopee

  // Estoque mínimo padrão
  minStock Int @default(5)

  // Status
  active Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relações
  variants   ProductVariant[]
  attributes ProductAttribute[]
}

// Atributos do produto (tipo de variação como "Cor", "Modelo iPhone", etc)
model ProductAttribute {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  name String // "Cor", "Modelo iPhone"
  type String // "color", "model", "size", etc

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relações
  attributeValues ProductAttributeValue[]

  @@unique([productId, name])
}

// Valores de atributos (ex: "Preto", "Rosa" para cor)
model ProductAttributeValue {
  id          String           @id @default(cuid())
  attributeId String
  attribute   ProductAttribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)

  value String // "Preto", "Rosa", "iPhone 14 Pro Max"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relações
  variantAttributes VariantAttributeValue[]

  @@unique([attributeId, value])
}

// Variação de produto (combina múltiplos atributos)
model ProductVariant {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  // Modelo e Cor (novo sistema)
  modelId String?
  model   DeviceModel? @relation(fields: [modelId], references: [id], onDelete: SetNull)
  colorId String?
  color   DeviceColor? @relation(fields: [colorId], references: [id], onDelete: SetNull)

  cod   String  @unique // Código da variação (ex: "VAR-001")
  image String? // Imagem específica da variante (opcional)

  // Preços específicos da variante (sobrescreve o do produto)
  purchaseCost     Float? // Se null, usa basePrice do Product
  boxCost          Float?
  mlTariff         Float  @default(0) // Tarifa Mercado Livre
  deliveryTariff   Float  @default(0) // Tarifa entrega Mercado Livre
  salePrice        Float // Preço de venda
  calculatedMargin Float?

  // Estoque
  stock Int @default(0)

  // Anúncios em Marketplaces
  mlListed     Boolean @default(false)
  mlListingId  String?
  mlListingUrl String?

  shopeeListed     Boolean @default(false)
  shopeeListingId  String?
  shopeeListingUrl String?

  active Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relações
  attributes VariantAttributeValue[]
  orderItems OrderItem[]
  mlProducts MLProduct[]
}

// Associação entre variante e valores de atributos
model VariantAttributeValue {
  id        String         @id @default(cuid())
  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  attributeValueId String
  attributeValue   ProductAttributeValue @relation(fields: [attributeValueId], references: [id], onDelete: Cascade)

  @@unique([variantId, attributeValueId])
}

model Order {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  status String @default("pending") // pending, processing, shipped, delivered
  total  Float

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relações
  items OrderItem[]
}

model OrderItem {
  id      String @id @default(cuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id])

  quantity Int
  price    Float

  @@unique([orderId, variantId])
}

// Integração com Mercado Livre
model MLIntegration {
  id           String   @id @default(cuid())
  accessToken  String   @db.Text
  refreshToken String?  @db.Text
  sellerID     String
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relações
  products MLProduct[]
}

model MLProduct {
  id        String         @id @default(cuid())
  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  mlListingID  String   @unique // ID do produto no Mercado Livre
  mlSKU        String?
  syncedAt     DateTime @default(now())
  lastSyncedAt DateTime @updatedAt
  syncStatus   String   @default("synced") // synced, pending, failed
  syncError    String?

  mlIntegrationId String
  mlIntegration   MLIntegration @relation(fields: [mlIntegrationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([variantId, mlIntegrationId])
}
