// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  username  String   @unique
  password  String
  name      String?
  image     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relações
  orders Order[]
}

model Product {
  id          String   @id @default(cuid())
  name        String
  description String
  price       Float
  image       String
  category    String   @default("Capinhas")
  stock       Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relações
  orderItems OrderItem[]
  mlProducts MLProduct[] // Produtos sincronizados para ML
}

model Order {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  status String @default("pending") // pending, processing, shipped, delivered
  total  Float

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relações
  items OrderItem[]
}

model OrderItem {
  id      String @id @default(cuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id])

  quantity Int
  price    Float

  @@unique([orderId, productId])
}

// Integração com Mercado Livre
model MLIntegration {
  id            String   @id @default(cuid())
  accessToken   String   @db.Text
  refreshToken  String?  @db.Text
  sellerID      String
  expiresAt     DateTime
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relações
  products MLProduct[]
}

model MLProduct {
  id              String   @id @default(cuid())
  productId       String
  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  mlListingID     String   @unique // ID do produto no Mercado Livre
  mlSKU           String?
  syncedAt        DateTime @default(now())
  lastSyncedAt    DateTime @updatedAt
  syncStatus      String   @default("synced") // synced, pending, failed
  syncError       String?
  
  mlIntegrationId String
  mlIntegration   MLIntegration @relation(fields: [mlIntegrationId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, mlIntegrationId])
}
