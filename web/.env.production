# Production Environment Variables

# NEON Database Connection (será preenchida pelo Vercel)
# Adicione no Vercel: https://vercel.com/docs/environment-variables
# DATABASE_URL=postgresql://user:password@ep-*.neon.tech/neondb?sslmode=require

# JWT Secret - DEVE SER CONFIGURADO NO VERCEL (não commitar valores reais)
# Gere um seguro com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=${JWT_SECRET}

# APP URL
NEXT_PUBLIC_APP_URL=https://seu-dominio.vercel.app
