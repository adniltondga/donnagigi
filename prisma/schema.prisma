// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Produto base (título do produto)
model Product {
  id          String   @id @default(cuid())
  name        String   // Título do produto
  description String?  @db.Text
  
  // Preço base e estoque
  baseSalePrice Float?
  minStock      Int     @default(0)
  
  // Mercado Livre
  mlListingId   String? @unique
  
  // Status
  active        Boolean @default(true)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  // Relações
  variants      ProductVariant[]
}

// Variação do produto (cor, tamanho, etc)
model ProductVariant {
  id        String   @id @default(cuid())
  
  // Relação com produto
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  // Informações
  title     String?  // Título específico da variante (ex: "Capinha iPhone 15 - Preto")
  cod       String   @unique
  
  // Preço e estoque
  salePrice Float
  stock     Int      @default(0)
  
  // Mercado Livre
  mlListingId String?
  
  // Status
  active    Boolean  @default(true)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relações
  mlProducts MLProduct[]
}

// Integração com Mercado Livre
model MLIntegration {
  id           String   @id @default(cuid())
  sellerID     String
  accessToken  String
  refreshToken String?
  expiresAt    DateTime
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  // Relações
  products     MLProduct[]
}

// Rastreamento de produtos no Mercado Livre
model MLProduct {
  id        String   @id @default(cuid())
  
  // Relação com variante
  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  
  // Relação com integração
  integrationId String
  integration   MLIntegration @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  
  // Dados do ML
  mlListingId   String?
  status        String   @default("active")
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
