// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  username  String   @unique
  password  String
  name      String?
  image     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relações
  orders Order[]
}

model Supplier {
  id          String   @id @default(cuid())
  name        String   @unique
  code        String   @unique // "capa25", etc
  email       String?
  whatsapp    String?
  address     String?
  city        String?
  state       String?
  contactPerson String?
  notes       String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Product {
  id                  String   @id @default(cuid())
  name                String
  description         String
  image               String
  
  // Dados do produto
  baseModel           String?  // "iPhone 14 Pro Max"
  colorVariant        String?  // "preta", "rosa", etc
  category            String   @default("Capinhas")
  supplier            String?  // "capa25"
  
  // Preços e custos (em reais)
  purchaseCost        Float    @default(0)    // Custo do produto
  boxCost             Float    @default(0)    // Custo da caixa para envio
  mlTariff            Float    @default(0)    // Tarifa Mercado Livre
  deliveryTariff      Float    @default(0)    // Tarifa entrega Mercado Livre
  salePrice           Float                   // Valor de venda (preço)
  calculatedMargin    Float?                  // Margem calculada automaticamente
  
  // Estoque
  stock               Int      @default(0)
  minStock            Int      @default(5)    // Alerta quando estoque baixo
  
  // Anúncios em Marketplaces
  mlListed            Boolean  @default(false) // Anunciado no Mercado Livre?
  mlListingId         String?                  // ID do anúncio no ML
  mlListingUrl        String?                  // URL do anúncio no ML
  
  shopeeListed        Boolean  @default(false) // Anunciado na Shopee?
  shopeeListingId     String?                  // ID do anúncio na Shopee
  shopeeListingUrl    String?                  // URL do anúncio na Shopee
  
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Relações
  orderItems          OrderItem[]
  mlProducts          MLProduct[]
}

model Order {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  status String @default("pending") // pending, processing, shipped, delivered
  total  Float

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relações
  items OrderItem[]
}

model OrderItem {
  id      String @id @default(cuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id])

  quantity Int
  price    Float

  @@unique([orderId, productId])
}

// Integração com Mercado Livre
model MLIntegration {
  id            String   @id @default(cuid())
  accessToken   String   @db.Text
  refreshToken  String?  @db.Text
  sellerID      String
  expiresAt     DateTime
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relações
  products MLProduct[]
}

model MLProduct {
  id              String   @id @default(cuid())
  productId       String
  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  mlListingID     String   @unique // ID do produto no Mercado Livre
  mlSKU           String?
  syncedAt        DateTime @default(now())
  lastSyncedAt    DateTime @updatedAt
  syncStatus      String   @default("synced") // synced, pending, failed
  syncError       String?
  
  mlIntegrationId String
  mlIntegration   MLIntegration @relation(fields: [mlIntegrationId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, mlIntegrationId])
}
