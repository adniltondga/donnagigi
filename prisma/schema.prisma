// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Tenant (cliente do SaaS agLivre). Cada cliente que se cadastra no
// produto cria um Tenant; todos os dados (produtos, bills, integrações,
// custos, fornecedores) são escopados por tenantId.
model Tenant {
  id        String   @id @default(cuid())
  name      String   // nome comercial exibido ao cliente
  slug      String   @unique // identificador URL-friendly (ex: "dona-gigi")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users          User[]
  products       Product[]
  bills          Bill[]
  suppliers      Supplier[]
  mlIntegrations MLIntegration[]
  mlProductCosts MLProductCost[]
}

// Usuário admin do sistema
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  username  String   @unique
  password  String
  name      String
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
}

// Produto base (título do produto)
model Product {
  id          String   @id @default(cuid())
  name        String   // Título do produto
  description String?  @db.Text

  // Preço base e estoque
  baseSalePrice Float?
  minStock      Int     @default(0)

  // Custos de venda
  productCost   Float?  // custo da mercadoria/produção

  // Mercado Livre
  mlListingId   String? @unique

  // Status
  active        Boolean @default(true)

  // Tenant owner
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relações
  variants      ProductVariant[]
  bills         Bill[]
  images        ProductImage[]

  @@index([tenantId])
}

// Imagens do produto
model ProductImage {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String   // URL final no Vercel Blob
  mlUrl     String?  // URL original do ML (referência)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Imagens da variação (específica para cada variação do produto)
model VariantImage {
  id        String         @id @default(cuid())
  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  url       String         // URL final no Vercel Blob
  mlUrl     String?        // URL original do ML (referência)
  order     Int            @default(0)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

// Variação do produto (cor, tamanho, etc)
model ProductVariant {
  id        String   @id @default(cuid())

  // Relação com produto
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  // Informações
  title     String?  // Título específico da variante (ex: "Capinha iPhone 15 - Preto")
  cod       String   @unique

  // Preço e estoque
  salePrice Float
  stock     Int      @default(0)

  // Mercado Livre
  mlListingId String?

  // Status
  active    Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relações
  mlProducts MLProduct[]
  images     VariantImage[]
}

// Custo cadastrado por listing do Mercado Livre.
// Usado pelo sync-orders para abater automaticamente em vendas recorrentes.
model MLProductCost {
  mlListingId String   @id
  title       String?
  productCost Float
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
}

// Estado temporário do fluxo OAuth PKCE do Mercado Livre
// Armazena o code_verifier gerado no /login, indexado pelo state,
// para ser recuperado no /callback sem depender de cookies.
model MLOAuthState {
  state        String   @id
  codeVerifier String
  tenantId     String?  // tenantId do usuário que iniciou o OAuth (setado no callback)
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@index([expiresAt])
}

// Integração com Mercado Livre
model MLIntegration {
  id           String   @id @default(cuid())
  sellerID     String
  accessToken  String
  refreshToken String?
  expiresAt    DateTime

  // Tenant owner (1 integração por tenant)
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relações
  products     MLProduct[]

  @@index([tenantId])
}

// Rastreamento de produtos no Mercado Livre
model MLProduct {
  id        String   @id @default(cuid())

  // Relação com variante
  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  // Relação com integração
  integrationId String
  integration   MLIntegration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  // Dados do ML
  mlListingId   String?
  status        String   @default("active")

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// Fornecedor
model Supplier {
  id        String   @id @default(cuid())
  name      String
  bills     Bill[]
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
}

// Conta (contas a pagar/receber)
model Bill {
  id              String   @id @default(cuid())
  type            String   // "payable" | "receivable"
  description     String
  amount          Float
  dueDate         DateTime
  paidDate        DateTime?
  status          String   @default("pending") // pending | paid | overdue | cancelled
  category        String   @default("outro") // fornecedor | marketplace_fee | venda | outro
  supplierId      String?
  supplier        Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  productId       String?   // relaciona com o produto vendido
  product         Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  notes           String?  @db.Text
  productCost     Float?   // custo total da mercadoria (custo unitário × quantity)
  quantity        Int      @default(1) // unidades vendidas no pedido (soma de order_items[].quantity)
  mlOrderId       String?  @unique  // evita duplicatas de pedidos ML
  mlPackId        String?  // pack_id do ML (ID que aparece no painel "vendas" do seller)
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId])
}
