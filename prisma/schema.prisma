// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  username  String   @unique
  password  String
  name      String?
  image     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relações
  orders Order[]
}

model Supplier {
  id        String   @id @default(cuid())
  name      String   @unique
  telephone String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relações
  bills Bill[]
}

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?  @default("")
  active      Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relações
  products Product[]
}

model Product {
  id          String   @id @default(cuid())
  
  // Mercado Livre
  mlListingId String? @unique // ID de anúncio no Mercado Livre
  
  // Informações básicas
  name        String   // Título do produto (do ML)
  description String?  @db.Text // Descrição
  
  // Preço e estoque
  baseSalePrice Float?  // Preço padrão
  minStock      Int     @default(0) // Estoque
  
  // Status
  active      Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relações
  variants    ProductVariant[]
}

// Variação de produto (cor, tamanho, etc)
model ProductVariant {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  // Informações
  title     String?  // Título específico da variante (ex: "Capinha iPhone 15 - Preto")
  cod       String   @unique // Código único
  
  // Preço e estoque
  salePrice Float    // Preço de venda
  stock     Int      @default(0) // Quantidade
  
  // Mercado Livre
  mlListingId String? // ID de anúncio da variante no ML
  
  // Status
  active    Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relações
  orderItems OrderItem[]
  mlProducts MLProduct[]
}

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?  @default("")
  active      Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relações
  products Product[]
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  username  String   @unique
  password  String
  name      String?
  image     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relações
  orders Order[]
}

model Supplier {
  id        String   @id @default(cuid())
  name      String   @unique
  telephone String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relações
  bills Bill[]
}

model Order {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  status String @default("pending") // pending, processing, shipped, delivered
  total  Float

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relações
  items OrderItem[]
}

model OrderItem {
  id      String @id @default(cuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variantId String
  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  quantity Int
  price    Float

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Bill {
  id        String   @id @default(cuid())
  type      String   // "purchase", "expense"
  dueDate   DateTime
  supplierId String?
  supplier  Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)

  amount    Float
  status    String   @default("pending") // pending, paid

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MLIntegration {
  id           String   @id @default(cuid())
  sellerID     String
  accessToken  String
  refreshToken String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relações
  products MLProduct[]
}

model MLProduct {
  id        String   @id @default(cuid())
  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  integrationId String
  integration   MLIntegration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  mlListingId String?
  status      String  @default("active")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Sale {
  id        String   @id @default(cuid())
  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  marketplace String   @default("mercado-livre") // "mercado-livre", "shopee"
  saleDate    DateTime @default(now())
  quantity    Int
  price       Float

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
